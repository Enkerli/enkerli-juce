#!/bin/bash
# suite-build — one entry point for building/validating any (or all) of the
# suite's JUCE plugin repos, instead of memorizing seven repos' worth of
# per-repo cmake incantations (BUILD.md §4, music-suite docs/KNOWLEDGE_TRANSFER.md
# item 2). Wraps, and does not replace, `validate.sh` — the automatable ladder
# (macOS build → hollow-bundle check → iOS compile → auval → pluginval) stays
# exactly as debugged there; this just knows WHICH repo needs WHICH ladder
# arguments, and adds the Linux leg validate.sh doesn't cover.
#
# Usage:
#   suite-build <repo[,repo...]|all> [--formats au,vst3,clap,lv2] [--ladder] [--fresh] [--ios] [--dry-run]
#   suite-build --list
#
# <repo> is a manifest alias below (midicurator, proggenie, pitchfold, vane,
# serpe, drawnqurve, workspace), a COMMA-separated list of aliases (e.g.
# `drawnqurve,serpe,proggenie` — no spaces), or "all". A list of 2+ aliases
# gets the same keep-going-and-summarize behavior as "all", just scoped to
# those repos. Repos are found as SIBLINGS of this script's enkerli-juce
# checkout by default (`$SUITE_ROOT/<dir>`), matched case-INSENSITIVELY if
# the exact GitHub casing (Vane, PitchFold, DrawnQurve) isn't what's on disk
# — override the whole sibling root with `export SUITE_ROOT=/path/to/parent`.
#
# music-suite is looked up separately, as `MUSIC_SUITE` (default
# `$SUITE_ROOT/music-suite`; override with `export MUSIC_SUITE=/path/to/
# music-suite`) — only consulted for midicurator/proggenie's WebUI-regen
# prebuild step. The OTHER five repos (pitchfold, vane, serpe, drawnqurve,
# workspace) find music-suite themselves at CMake time, independent of this
# script — see BUILD.md §4 in music-suite for their sibling/nested/
# `MUSIC_SUITE`-env/`webui.local.cmake` probing order.
#
# JUCE itself is looked up once via `JUCE_PATH` (default `$SUITE_ROOT/JUCE`;
# override with `export JUCE_PATH=/path/to/JUCE`) so all seven repos share
# ONE local JUCE checkout instead of each `FetchContent`-ing (and building)
# its own ~500MB copy — clone juce-framework/JUCE as an eighth sibling once
# and this just works. Same for CLAP: `CLAP_JUCE_PATH` is the analogous
# override, checked per-repo (`$repo/clap-juce-extensions` by default) since
# it isn't spread across repos the way JUCE_PATH is.
#
#   --ladder    Run the FULL automatable ladder (macOS: validate.sh's build +
#               hollow-bundle check + iOS compile + auval + pluginval; Linux:
#               the LV2/VST3/CLAP/Standalone build, no auval/pluginval — unavailable
#               there). Bare (no --ladder): a plain macOS `build` for a faster
#               inner loop, or the Linux build (there is no "quick" Linux path
#               distinct from the ladder — it's already just a cmake build).
#   --formats   Target filter, e.g. --formats vst3,clap → cmake --build
#               --target <Product>_VST3 <Product>_CLAP. Works on the quick
#               (non-ladder) macOS path AND the Linux path. Available formats
#               are platform-dependent: macOS builds au/vst3/clap/standalone,
#               Linux builds lv2/vst3/clap/standalone (no au — that's
#               Apple-only). Asking for a format the platform doesn't build
#               just gets a "target not found" from cmake. Has no effect
#               under --ladder — validate.sh's ladder is a fixed sequence. If
#               a repo's CMake doesn't name targets exactly this way, drop
#               --formats and let it build everything (documented per-repo
#               naming in BUILD.md is the source of truth if this guess is
#               wrong).
#   --fresh     Wipe build/build-ios/build-linux first — catches the stale/
#               hollow-bundle class of bug validate.sh's own check exists for
#               (a "successful" incremental build can still ship old bytes).
#   --ios       Also do the iOS unsigned compile, standalone from --ladder
#               (e.g. you want just the compile check, not the whole ladder).
#   --dry-run   Print every command instead of running it. Use this to sanity
#               check a repo/flag combination before committing to a real
#               build — especially useful on a machine you haven't run this
#               on before.
#
# `all` (or a comma-separated repo list) builds every repo it can find and
# keeps going past one that's missing or fails — a consolidation-in-progress
# checkout won't always have every sibling yet — then prints a pass/fail
# summary and exits non-zero if anything failed.
#
# Two repos (MIDIcurator, Progression Studio) commit their WebUI bundle
# instead of building it live — the trap that shipped GloriArp two weeks
# stale twice in July 2026. This script ALWAYS regenerates it first for those
# two, every invocation, so that trap can't recur through this entry point.
set -uo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JUCE_REPO="$(cd "$HERE/.." && pwd)"                      # .../enkerli-juce (this script lives in its tools/)
SUITE_ROOT="${SUITE_ROOT:-$(cd "$JUCE_REPO/.." && pwd)}" # parent of enkerli-juce, by default
MUSIC_SUITE="${MUSIC_SUITE:-$SUITE_ROOT/music-suite}"    # now actually read (2026-07-21 — the usage text
                                                          # promised this override for a while before the
                                                          # code did anything with it)
JUCE_PATH="${JUCE_PATH:-$SUITE_ROOT/JUCE}"               # one shared local JUCE for all seven repos (2026-07-21)
export JUCE_PATH                                         # enkerli_resolve_juce() (EnkerliPlugin.cmake) reads this
VALIDATE="$JUCE_REPO/tools/validate.sh"
DRY_RUN=0

# ── Manifest: alias -> "dir|type|code|product|prebuild|linux" ───────────────
# type: aumi (MIDI effect) | aumu (instrument). prebuild: shell command run
# in the repo dir before cmake, or "-" for none. linux: 1 if a build-linux
# (LV2/Standalone/CLAP) configuration is expected to work.
#
# A `case` lookup, not `declare -A`: this script's shebang (`#!/bin/bash`)
# always resolves to macOS's stock `/bin/bash`, frozen at 3.2.57 (the last
# GPLv2 release — Apple never shipped bash 4+) even when a newer bash is on
# PATH via Homebrew. Bash 3.2 has no associative arrays; `declare -A` there
# silently drops `-A`, and `[midicurator]=...` gets parsed as an *indexed*
# subscript — an arithmetic expression — which under `set -u` fails as
# "midicurator: unbound variable" (2026-07-21 field report). A `case`
# needs nothing newer than bash 3.2.
plugin_spec() {
  case "$1" in
    midicurator) printf '%s\n' "midicurator-plugin|aumi|Mcur|MIDIcurator|node WebUI/build.mjs ${MUSIC_SUITE}/apps/MIDIcurator|1" ;;
    proggenie)   printf '%s\n' "progression-studio-plugin|aumi|Prst|Progression Studio|node WebUI/build.mjs ${MUSIC_SUITE}/apps/progression-studio|1" ;;
    pitchfold)   printf '%s\n' "PitchFold|aumi|Pqf1|PitchFold|-|1" ;;
    vane)        printf '%s\n' "Vane|aumu|VAne|Vane|-|1" ;;
    serpe)       printf '%s\n' "rhythm_pattern_explorer|aumi|RPEd|Serpe|-|1" ;;
    drawnqurve)  printf '%s\n' "DrawnQurve|aumi|Dqau|DrawnQurve|-|1" ;;
    workspace)   printf '%s\n' "workspace-plugin|aumi|Wksp|Suite Workspace|-|1" ;;
    *) return 1 ;;
  esac
}
ORDER=(midicurator proggenie pitchfold vane serpe drawnqurve workspace)

# A repo dir under SUITE_ROOT, tolerant of case: the manifest above spells
# each dir with its real GitHub casing (Vane, PitchFold, DrawnQurve), but a
# clone can easily end up lowercase (a case-insensitive host filesystem, a
# script that normalized it, a manual `git clone ... vane`) — Linux itself
# is case-sensitive, so that mismatch used to be a hard FAIL even though the
# repo was right there. Exact match wins when present (no filesystem scan);
# otherwise one case-insensitive `find` at SUITE_ROOT's top level. Echoes
# nothing and returns 1 if neither exists — callers do their own reporting.
resolve_dir() {
  local root="$1" dir="$2"
  if [ -d "$root/$dir" ]; then printf '%s\n' "$root/$dir"; return 0; fi
  local found
  found="$(find "$root" -maxdepth 1 -iname "$dir" -type d 2>/dev/null | head -1)"
  [ -n "$found" ] && { printf '%s\n' "$found"; return 0; }
  return 1
}

usage() {
  sed -n '2,58p' "${BASH_SOURCE[0]}" | sed 's/^# \?//'
  exit "${1:-0}"
}

# Maps one --formats token to this repo's cmake target name. Shared by the
# macOS quick-build path and the Linux path (Linux only ever has standalone/
# lv2/clap targets to actually pick from — asking for au/vst3 there just
# gets a "target not found" from cmake itself, which is clear enough).
# Returns 1 (no output) for an unrecognized token; caller reports it.
format_target() {
  local product="$1" fmt="$2"
  case "$fmt" in
    standalone) printf '%s\n' "${product// /}_Standalone" ;;
    au)         printf '%s\n' "${product// /}_AU" ;;
    vst3)       printf '%s\n' "${product// /}_VST3" ;;
    clap)       printf '%s\n' "${product// /}_CLAP" ;;
    lv2)        printf '%s\n' "${product// /}_LV2" ;;
    *) return 1 ;;
  esac
}

list() {
  printf '%-12s %-28s %-5s %-5s %s\n' ALIAS DIR TYPE CODE PRODUCT
  for a in "${ORDER[@]}"; do
    IFS='|' read -r dir type code product _ _ <<<"$(plugin_spec "$a")"
    printf '%-12s %-28s %-5s %-5s %s\n' "$a" "$dir" "$type" "$code" "$product"
  done
  exit 0
}

# Hard-exit for argument-parsing problems, before any repo is touched.
usage_fail() { printf 'FAIL: %s\n' "$1" >&2; exit 1; }

run() {
  if [ "$DRY_RUN" = 1 ]; then printf '+ %s\n' "$*"; else eval "$@"; fi
}

# Returns 1 (does NOT exit the whole script) — so `all` can keep going past
# one repo that's absent or fails, and a single-repo invocation still exits
# non-zero at the end via build_one's own return value.
build_one() {
  local alias="$1"
  local spec
  if ! spec="$(plugin_spec "$alias")"; then
    printf 'FAIL: unknown repo alias "%s" — suite-build --list\n' "$alias" >&2
    return 1
  fi
  local dir type code product prebuild linux
  IFS='|' read -r dir type code product prebuild linux <<<"$spec"
  local path
  path="$(resolve_dir "$SUITE_ROOT" "$dir")" || {
    printf 'FAIL: %s: not found at %s (case-insensitive search also came up empty) — set SUITE_ROOT, or check it out as a sibling\n' "$alias" "$SUITE_ROOT/$dir" >&2
    return 1
  }

  printf '\n=== %s (%s) ===\n' "$product" "$path"
  (
    # set -e HERE (not at script scope) is defense-in-depth, not the actual
    # failure mechanism: when this whole subshell is invoked as `if build_one
    # ...; then` (every "all"/multi-repo run), bash SUPPRESSES errexit for
    # the entire compound command being tested — including in here, even
    # though this is its own subshell (a real 2026-07-21 field report: a
    # cmake --build failure printed its error but the summary still said
    # "OK", because nothing downstream of the failure ever re-checked $?).
    # So every step below that must be fatal checks its own exit status
    # explicitly via `|| exit 1` — never relying on implicit -e propagation.
    set -euo pipefail
    cd "$path" || exit 1

    if [ "$prebuild" != "-" ]; then
      if [ ! -d "$MUSIC_SUITE" ]; then
        printf 'FAIL: %s: music-suite not found at %s — set MUSIC_SUITE, or check it out as a sibling named "music-suite"\n' "$alias" "$MUSIC_SUITE" >&2
        exit 1
      fi
      printf -- '— WebUI regen (committed bundle: %s)\n' "$product"
      run "$prebuild" || exit 1
    fi

    if [ "$FRESH" = 1 ]; then
      printf -- '— fresh: wiping build dirs\n'
      run "rm -rf build build-ios build-linux build-macos build-mac" || exit 1
    fi

    is_linux=0
    [ "$(uname -s)" = "Linux" ] && is_linux=1

    if [ "$is_linux" = 1 ]; then
      if [ "$linux" != 1 ]; then
        printf 'FAIL: %s: no Linux build documented for this repo (BUILD.md) — check by hand first\n' "$alias" >&2
        exit 1
      fi
      run "cmake -B build-linux" || exit 1

      # The LV2 target's manifest step runs the built plugin headlessly to
      # introspect it; without a display that can crash (Gtk "cannot open
      # display" / SIGPIPE — a real 2026-07-21 field report). xvfb-run gives
      # it a throwaway virtual one; Standalone/CLAP don't need this at all.
      XVFB=""
      if command -v xvfb-run >/dev/null 2>&1; then
        XVFB="xvfb-run -a"
      else
        printf 'NOTE: xvfb-run not found (apt/dnf/pacman package "xvfb") — if the\n      LV2 target fails below with "cannot open display" or a SIGPIPE\n      (exit 141), that'"'"'s why; Standalone and CLAP are unaffected.\n' >&2
      fi

      if [ -n "$FORMATS" ]; then
        targets=()
        IFS=',' read -ra fs <<<"$FORMATS"
        for f in "${fs[@]}"; do
          t="$(format_target "$product" "$f")" || {
            printf 'FAIL: unknown format "%s" (Linux builds: lv2, vst3, clap, standalone — no au)\n' "$f" >&2
            exit 1
          }
          targets+=("$t")
        done
        printf -- '— Linux: %s\n' "$FORMATS"
        run "$XVFB cmake --build build-linux -j\$(nproc) --target ${targets[*]}" || exit 1
      else
        printf -- '— Linux: LV2/VST3/CLAP/Standalone\n'
        run "$XVFB cmake --build build-linux -j\$(nproc)" || exit 1
      fi
      exit 0
    fi

    # macOS.
    if [ "$LADDER" = 1 ]; then
      printf -- '— full ladder via validate.sh\n'
      run "\"$VALIDATE\" \"$path\" \"$type\" \"$code\" \"$product\"" || exit 1
    else
      printf -- '— quick build (add --ladder for the full automatable ladder)\n'
      if [ -n "$FORMATS" ]; then
        targets=()
        IFS=',' read -ra fs <<<"$FORMATS"
        for f in "${fs[@]}"; do
          t="$(format_target "$product" "$f")" || {
            printf 'FAIL: unknown format "%s" (au, vst3, clap, lv2, standalone)\n' "$f" >&2
            exit 1
          }
          targets+=("$t")
        done
        run "cmake -B build -DCMAKE_BUILD_TYPE=Release" || exit 1
        run "cmake --build build --target ${targets[*]}" || exit 1
      else
        run "cmake -B build -DCMAKE_BUILD_TYPE=Release" || exit 1
        run "cmake --build build -j 8" || exit 1
      fi
    fi

    if [ "$IOS" = 1 ] && [ "$LADDER" != 1 ]; then
      printf -- '— iOS unsigned compile\n'
      run "cmake -B build-ios -G Xcode -DCMAKE_SYSTEM_NAME=iOS -DCMAKE_OSX_DEPLOYMENT_TARGET=16.0" || exit 1
      run "cmake --build build-ios --config Release -- CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO" || exit 1
    fi
  )
}

# ── Arg parsing ───────────────────────────────────────────────────────────
[ $# -eq 0 ] && usage 1
REPO=""
FORMATS=""
LADDER=0
FRESH=0
IOS=0
while [ $# -gt 0 ]; do
  case "$1" in
    --list) list ;;
    --help|-h) usage 0 ;;
    --ladder) LADDER=1 ;;
    --fresh) FRESH=1 ;;
    --ios) IOS=1 ;;
    --dry-run) DRY_RUN=1 ;;
    --formats) FORMATS="$2"; shift ;;
    --formats=*) FORMATS="${1#--formats=}" ;;
    -*) usage_fail "unknown flag $1 (--help for usage)" ;;
    *) [ -z "$REPO" ] || usage_fail "one repo, comma-list, or \"all\" at a time"; REPO="$1" ;;
  esac
  shift
done
[ -n "$REPO" ] || usage 1

if [ "$REPO" = "all" ]; then
  SELECTED=("${ORDER[@]}")
else
  IFS=',' read -ra SELECTED <<<"$REPO"   # a bare alias is just a 1-element list
fi

if [ "${#SELECTED[@]}" -gt 1 ]; then
  overall=0
  results=()
  for a in "${SELECTED[@]}"; do
    if build_one "$a"; then results+=("  OK     $a"); else results+=("  FAILED $a"); overall=1; fi
  done
  printf '\n— summary —\n%s\n' "$(printf '%s\n' "${results[@]}")"
  [ "$overall" = 0 ] && printf '\nAll done.\n' || printf '\nOne or more repos failed — see above.\n'
  exit "$overall"
else
  build_one "${SELECTED[0]}"
  status=$?
  [ "$status" = 0 ] && printf '\nDone.\n'
  exit "$status"
fi
